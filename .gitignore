# --- DOSSIERS DE BUILD ---
# Fichiers générés par Gradle et le processus de compilation (temporaires et caches)
.gradle
/build
/captures
/app/release
.externalNativeBuild
.cxx

# --- CONFIGURATION LOCALE & SECRETS ---
# local.properties contient le chemin vers le SDK Android propre à votre machine
/local.properties
local.properties

# Fichiers de configuration sensibles (Clés d'API, services Google, secrets)
google-services.json
secrets.xml

# --- SIGNATURE DE L'APPLICATION (CRITIQUE) ---
# Clés de signature (.jks, .keystore) : ne doivent JAMAIS être commitées pour des raisons de sécurité
*.jks
*.keystore
*.p12

# --- CONFIGURATION DE L'IDE ---
# Paramètres spécifiques à Android Studio / IntelliJ (peuvent varier d'un développeur à l'autre)
*.iml
*.ipr
*.iws
.idea/

# --- SYSTÈME D'EXPLOITATION ---
# Fichiers temporaires créés par macOS
.DS_Store

# --- FASTLANE ---
# Rapports, logs et captures d'écran générés automatiquement lors de l'automatisation du déploiement
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output
